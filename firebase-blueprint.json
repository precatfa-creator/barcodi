{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "Public sanitized store profile structure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeName": { "type": "string" },
        "storeLogo": { "type": "string" },
        "visits": { "type": "integer" },
        "products": {
          "type": "array",
          "items": { "$ref": "#/entities/Product" }
        },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "storeName"]
    },
    "Product": {
      "title": "Product",
      "description": "Store catalog product item",
      "type": "object",
      "properties": {
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["barcode", "name", "price"]
    },
    "PrivateStore": {
      "title": "PrivateStore",
      "description": "Server-only private store record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "passwordHash": { "type": "string" },
        "storeName": { "type": "string" },
        "storeLogo": { "type": "string" },
        "visits": { "type": "integer" },
        "products": {
          "type": "array",
          "items": { "$ref": "#/entities/Product" }
        },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "username", "passwordHash", "storeName"]
    }
  },
  "firestore": {
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Public sanitized retail store data"
    },
    "/privateStores/{storeId}": {
      "schema": "PrivateStore",
      "description": "Server-only private store records with usernames and password hashes"
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Disabled; products are published inside sanitized store documents"
    }
  }
}
