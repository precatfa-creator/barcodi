# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public frontend URL.
APP_URL="https://YOUR_NETLIFY_SITE.netlify.app"

JWT_SECRET="replace-with-at-least-32-random-bytes"
ADMIN_USERNAME="commander"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Optional: comma-separated allowed browser origins. Defaults to APP_URL in production.
CORS_ORIGIN="https://YOUR_NETLIFY_SITE.netlify.app"

# Netlify build-time variable used to generate the /api proxy redirect.
BACKEND_URL="https://YOUR_CLOUD_RUN_SERVICE_URL"

# Supabase server-side database connection.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# Optional product import guardrail.
MAX_PRODUCTS_PER_STORE="5000"
